# Copia este archivo a ".env" y completa los valores reales.
# NUNCA subas el archivo ".env" a GitHub (ya está en .gitignore).

# Base de datos Postgres de Supabase (Settings > Database > Connection string)
DATABASE_URL="postgresql://usuario:contraseña@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://usuario:contraseña@host:5432/postgres"

# Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="clave-publica-anon"
SUPABASE_SERVICE_ROLE_KEY="clave-secreta-service-role"

# IA (Anthropic) — SOLO en el servidor, nunca en el frontend
ANTHROPIC_API_KEY="sk-ant-..."

# Email transaccional (Resend) para alertas
RESEND_API_KEY="re_..."
